#!/usr/bin/env bash

# If not running interactively, don't do anything
[[ $- != *i* ]] && return

#######################################################################
# Shell Options                                                       #
#######################################################################

shopt -s histappend     # Append to history, don't overwrite
shopt -s checkwinsize   # Check window size after each command
shopt -s globstar       # Allow ** for recursive matching

#######################################################################
# History                                                             #
#######################################################################

export HISTSIZE=10000
export HISTFILESIZE=20000
export HISTCONTROL=ignoreboth:erasedups
export HISTIGNORE="ls:ll:cd:pwd:exit:clear:history"
export HISTTIMEFORMAT="%F %T "

# Immediately write history
export PROMPT_COMMAND="history -a; history -c; history -r; $PROMPT_COMMAND"

########################################################################
# Environment Variables                                                #
########################################################################

# Path configuration
export PATH="$HOME/.local/bin:$PATH"

# Default editor
export EDITOR=$(command -v nvim || command -v vim || command -v nano)
export VISUAL="$EDITOR"

########################################################################
# Modular configuration                                                #
########################################################################

BASH_CONFIG_DIR="$HOME/.config/bash"

if [ -d "$BASH_CONFIG_DIR" ]; then
  for config in "$BASH_CONFIG_DIR"/*.bash; do
    if [ -f "$config" ]; then
      source "$config" || true
    fi
  done

  if [ -d "$BASH_CONFIG_DIR/functions" ]; then
    for func in "$BASH_CONFIG_DIR/functions"/*.bash; do
      if [ -f "$func" ]; then
        source "$func" || true
      fi
    done
  fi
fi

#######################################################################
# Completion                                                          #
#######################################################################

# Enable bash completion
if ! shopt -oq posix; then
  if [ -f /usr/share/bash-completion/bash_completion ]; then
    . /usr/share/bash-completion/bash_completion
  elif [ -f /etc/bash_completion ]; then
    . /etc/bash_completion
  fi
fi

#######################################################################
# Local Overrides                                                     #
#######################################################################

if [ -f "$HOME/.bashrc.local" ]; then
  . "$HOME/.bashrc.local"
fi

